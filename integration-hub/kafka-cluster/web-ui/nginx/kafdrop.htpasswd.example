# Example only — do NOT commit a real kafdrop.htpasswd.
# Generate the real file locally per the readme:
#
#   htpasswd -B -c nginx/kafdrop.htpasswd <username>
#
# Add more users with:
#
#   htpasswd -B nginx/kafdrop.htpasswd <another-user>
#
admin:$2y$05$REPLACE_WITH_REAL_BCRYPT_HASH_FROM_HTPASSWD_COMMAND
